---
import Footer from '../components/sections/Footer.jsx';
import Navbar from '../components/layout/Navbar.jsx';
import BuildYourOwnCakePage from '../components/forms/BuildYourOwnCakePage.jsx';
import BaseLayout from '../layouts/BaseLayout.astro';
import { footerContent, navigationItems, siteIdentity } from '../content/siteContent';
---

<BaseLayout title="Get a Quote | Isa's Cakes">
  <Navbar client:load items={navigationItems} identity={siteIdentity} />
  <main id="main-content">
    <BuildYourOwnCakePage client:load />
  </main>
  <Footer content={footerContent} identity={siteIdentity} />
</BaseLayout>
