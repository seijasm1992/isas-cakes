---
import Footer from '../components/sections/Footer.jsx';
import Navbar from '../components/layout/Navbar.jsx';
import BuildYourOwnCakePage from '../components/forms/BuildYourOwnCakePage.jsx';
import BaseLayout from '../layouts/BaseLayout.astro';
import { footerContent, navigationItems, siteIdentity } from '../content/siteContent';

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: "Get a Custom Cake Quote — Isa's Cakes",
    description:
      'Request a personalized cake quote for your next celebration. Share your vision and receive a custom price within 24 hours from Isa\'s Cakes.',
    url: 'https://isascakes.com/build-your-own-cake',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      {
        '@type': 'ListItem',
        position: 1,
        name: 'Home',
        item: 'https://isascakes.com/',
      },
      {
        '@type': 'ListItem',
        position: 2,
        name: 'Get a Quote',
        item: 'https://isascakes.com/build-your-own-cake',
      },
    ],
  },
];
---

<BaseLayout
  title="Get a Custom Cake Quote | Isa's Cakes Miami"
  description="Request a personalized cake quote for your next celebration. Share your vision and receive a custom price within 24 hours from Isa's Cakes."
  schema={schema}
>
  <Navbar client:load items={navigationItems} identity={siteIdentity} />
  <main id="main-content">
    <BuildYourOwnCakePage client:load />
  </main>
  <Footer content={footerContent} identity={siteIdentity} />
</BaseLayout>
