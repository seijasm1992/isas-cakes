---
import AboutStory from '../components/sections/AboutStory.jsx';
import Footer from '../components/sections/Footer.jsx';
import Navbar from '../components/layout/Navbar.jsx';
import BaseLayout from '../layouts/BaseLayout.astro';
import { aboutContent, footerContent, navigationItems, siteIdentity } from '../content/siteContent';

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'AboutPage',
    name: "About Isa's Cakes",
    description:
      "Discover the journey behind Isa's Cakes — from homemade beginnings to refined custom cake craftsmanship serving Miami celebrations.",
    url: 'https://isascakes.com/about',
    mainEntity: {
      '@type': 'Organization',
      name: "Isa's Cakes",
      url: 'https://isascakes.com',
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      {
        '@type': 'ListItem',
        position: 1,
        name: 'Home',
        item: 'https://isascakes.com/',
      },
      {
        '@type': 'ListItem',
        position: 2,
        name: 'About',
        item: 'https://isascakes.com/about',
      },
    ],
  },
];
---

<BaseLayout
  title="About Isa | The Story Behind Isa's Cakes Miami"
  description="Discover the journey behind Isa's Cakes — from homemade beginnings to refined custom cake craftsmanship serving Miami celebrations."
  image="/about/IMG_2436eee-copy.webp"
  schema={schema}
>
  <Navbar client:load items={navigationItems} identity={siteIdentity} />
  <main id="main-content">
    <AboutStory client:load content={aboutContent} identity={siteIdentity} />
  </main>
  <Footer content={footerContent} identity={siteIdentity} />
</BaseLayout>
