---
import ComplementaryProducts from '../components/sections/ComplementaryProducts.jsx';
import Footer from '../components/sections/Footer.jsx';
import Navbar from '../components/layout/Navbar.jsx';
import Reviews from '../components/sections/Reviews.jsx';
import Hero from '../components/sections/Hero.jsx';
import TopSkills from '../components/sections/TopSkills.jsx';
import BaseLayout from '../layouts/BaseLayout.astro';
import {
  complementaryProducts,
  footerContent,
  heroSlides,
  navigationItems,
  reviewsContent,
  siteIdentity,
  topSkills,
} from '../content/siteContent';
---

<BaseLayout>
  <Navbar client:load items={navigationItems} identity={siteIdentity} />
  <main id="main-content">
    <Hero client:load slides={heroSlides} identity={siteIdentity} />
    <ComplementaryProducts client:load content={complementaryProducts} />
    <TopSkills content={topSkills} />
    <Reviews content={reviewsContent} />
  </main>
  <Footer content={footerContent} identity={siteIdentity} />
</BaseLayout>
