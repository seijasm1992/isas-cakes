---
import AboutStory from '../components/sections/AboutStory.jsx';
import Footer from '../components/sections/Footer.jsx';
import Navbar from '../components/layout/Navbar.jsx';
import BaseLayout from '../layouts/BaseLayout.astro';
import { aboutContent, footerContent, navigationItems, siteIdentity } from '../content/siteContent';
---

<BaseLayout
  title="About Isa | Isa's Cakes"
  description="Learn the story behind Isa's Cakes, from humble beginnings to refined custom cake craftsmanship."
>
  <Navbar client:load items={navigationItems} identity={siteIdentity} />
  <main id="main-content">
    <AboutStory client:load content={aboutContent} identity={siteIdentity} />
  </main>
  <Footer content={footerContent} identity={siteIdentity} />
</BaseLayout>
